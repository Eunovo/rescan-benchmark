+#!/usr/bin/env python3
+
+from collections import defaultdict
+from test_framework.address import address_to_scriptpubkey
+from test_framework.blocktools import create_block, create_coinbase
+from test_framework.messages import CBlockHeader, CTxOut, msg_block, msg_headers
+from test_framework.p2p import P2PInterface
+from test_framework.test_framework import BitcoinTestFramework
+from test_framework.util import assert_equal
+
+import time
+
+CHAIN_LENGTH = 2000
+KEYPOOL_SIZE = 100
+INTERVALS = [0, 5, 10, 50, 100, 500, CHAIN_LENGTH+1] # For interval CHAIN_LENGTH+1, there will be no payments in the chain
+THREADS = [1, 2, 4, 8, 16]
+
+# Blocks are announced/submitted to the node in batches over p2p.
+BATCH_SIZE = 2000
+
+# Number of keypool-sized groups to derive per deriveaddresses RPC call.
+DERIVE_STEP_SIZE = 5
+
+class BaseNode(P2PInterface):
+    def send_header_for_blocks(self, new_blocks):
+        headers_message = msg_headers()
+        headers_message.headers = [CBlockHeader(b) for b in new_blocks]
+        self.send_without_ping(headers_message)
+
+class RescanBenchmark(BitcoinTestFramework):
+    def add_options(self, parser):
+        parser.add_argument('--output_file', dest='output_file', default='', help='File to write benchmark results to')
+        parser.add_argument('--worstcase', action='store_true', default=False,
+                            help='Pay to end-of-range addresses so every payment triggers a top-up (default: pay sequentially, top-up every KEYPOOL_SIZE payments)')
+
+    def set_test_params(self):
+        self.num_nodes = 1
+        self.setup_clean_chain = True
+
+    def skip_test_if_missing_module(self):
+        self.skip_if_no_wallet()
+
+    ### Returns (min, max, avg). Each iteration gets a fresh cold wallet, since a wallet that
+    ### already scanned the chain would have its keypool topped up and its transactions
+    ### recorded, defeating both the top-up measurement (--worstcase) and the point of rescanning.
+    def benchmark(self, node, interval, stop_height, wallet_prefix, iters: int = 3) -> (int, int, int):
+        min_time = float('inf')
+        max_time = 0
+        total_time = 0
+
+        for i in range(iters):
+            wallet_name = f'{wallet_prefix}_{i}'
+            node.createwallet(wallet_name=wallet_name, disable_private_keys=True, blank=True, descriptors=True)
+            wallet = node.get_wallet_rpc(wallet_name)
+            assert_equal(wallet.getwalletinfo()['txcount'], 0)
+
+            start_time = time.perf_counter_ns()
+            import_result = wallet.importdescriptors([{
+                'desc': self.interval_descriptors[interval],
+                'timestamp': 0,
+                'range': [0, KEYPOOL_SIZE - 1],
+            }])
+            end_time = time.perf_counter_ns()
+
+            assert_equal(import_result[0]['success'], True)
+            self.assert_payments_received(wallet, interval)
+            node.unloadwallet(wallet_name)
+
+            elapsed = end_time - start_time
+            min_time = min(min_time, elapsed)
+            max_time = max(max_time, elapsed)
+            total_time += elapsed
+
+        avg_time = total_time // iters
+        return min_time, max_time, avg_time
+
+    ### Number of blocks between payments for a given interval (interval 0 means every block)
+    def payment_step(self, interval: int) -> int:
+        return interval if interval > 0 else 1
+
+    ### Number of payments an interval's descriptor should have received in the built chain
+    def expected_payment_count(self, interval: int) -> int:
+        return CHAIN_LENGTH // self.payment_step(interval) if interval <= CHAIN_LENGTH else 0
+
+    ### Asserts the wallet has recorded exactly the expected number of payments for the interval
+    def assert_payments_received(self, wallet, interval):
+        expected = self.expected_payment_count(interval)
+        txs = wallet.listtransactions('*', 1000000)
+        # Payments are extra coinbase outputs, so category is 'generate' (mature) or
+        # 'immature' — not 'receive'. Exclude 'send' to count only incoming payments.
+        received = [tx for tx in txs if tx['category'] != 'send']
+        assert_equal(len(received), expected)
+
+    ### Builds a single chain of blocks in-process, paying the pre-computed scripts at each height.
+    def build_chain(self, tip, block_time, scripts_for_height):
+        blocks = []
+        for height in range(1, CHAIN_LENGTH + 1):
+            coinbase = create_coinbase(height)
+            for script in scripts_for_height.get(height, []):
+                coinbase.vout.append(CTxOut(0, script))
+            block = create_block(tip, coinbase, ntime=block_time)
+            block.solve()
+            blocks.append(block)
+            tip = block.hash_int
+            block_time += 1
+        return blocks
+
+    ### Submits pre-built blocks to the node over p2p, announcing headers in batches first.
+    def submit_chain(self, node, blocks):
+        p2p = node.add_p2p_connection(BaseNode())
+        for i in range(0, len(blocks), BATCH_SIZE):
+            p2p.send_header_for_blocks(blocks[i:i + BATCH_SIZE])
+        for block in blocks:
+            p2p.send_without_ping(msg_block(block))
+        p2p.sync_with_ping(timeout=960)
+        node.disconnect_p2ps()
+
+    def run_test(self):
+        node = self.nodes[0]
+        self.restart_node(0, ['-blockfilterindex=1', f'-keypool={KEYPOOL_SIZE}'])
+
+        self.interval_descriptors = {}
+        scripts_for_height = defaultdict(list)
+
+        self.log.info("Creating interval wallets and pre-computing payment addresses")
+        for interval in INTERVALS:
+            wallet_name = f'keys_{interval}'
+            node.createwallet(wallet_name=wallet_name)
+            w = node.get_wallet_rpc(wallet_name)
+
+            # Use the external (non-internal) ranged descriptor for this interval's payments.
+            descs = w.listdescriptors()['descriptors']
+            external_desc = next(d for d in descs if 'range' in d and not d.get('internal'))
+            self.interval_descriptors[interval] = external_desc['desc']
+
+            payment_count = self.expected_payment_count(interval)
+            step = self.payment_step(interval)
+
+            if self.options.worstcase:
+                # Payment k goes to index k*KEYPOOL_SIZE - 1 (end of the k-th keypool range),
+                # so every payment triggers a top-up during rescan.
+                for chunk_start in range(0, payment_count, DERIVE_STEP_SIZE):
+                    chunk_end = min(chunk_start + DERIVE_STEP_SIZE, payment_count)
+                    # Derive several multiples of KEYPOOL_SIZE addresses (DERIVE_STEP_SIZE)
+                    # so we can obtain multiple end of range addresses at once
+                    addrs = w.deriveaddresses(external_desc['desc'], [chunk_start * KEYPOOL_SIZE, chunk_end * KEYPOOL_SIZE - 1])
+                    for i in range(0, chunk_end - chunk_start):
+                        payment_num = i + chunk_start + 1
+                        height = payment_num * step
+                        scripts_for_height[height].append(address_to_scriptpubkey(addrs[(i + 1) * KEYPOOL_SIZE - 1]))
+            else:
+                # Payment k goes to the next sequential index (k-1, 0-indexed).
+                # A top-up is triggered once every KEYPOOL_SIZE payments instead of every payment.
+                sequential_chunk = DERIVE_STEP_SIZE * KEYPOOL_SIZE
+                for chunk_start in range(0, payment_count, sequential_chunk):
+                    chunk_end = min(chunk_start + sequential_chunk, payment_count)
+                    addrs = w.deriveaddresses(external_desc['desc'], [chunk_start, chunk_end - 1])
+                    for i in range(0, chunk_end - chunk_start):
+                        payment_num = i + chunk_start + 1
+                        height = payment_num * step
+                        scripts_for_height[height].append(address_to_scriptpubkey(addrs[i]))
+
+            node.unloadwallet(wallet_name)
+
+        self.log.info("Building chain blocks in-process")
+        tip = int(node.getbestblockhash(), 16)
+        block_time = node.getblock(node.getbestblockhash())['time'] + 1
+        blocks = self.build_chain(tip, block_time, scripts_for_height)
+
+        self.log.info("Submitting chain to the node over p2p")
+        self.submit_chain(node, blocks)
+        assert_equal(node.getblockcount(), CHAIN_LENGTH)
+
+        results = []
+        for interval in INTERVALS:
+            self.log.info(f"Benchmarking rescanblockchain with interval {interval}")
+
+            self.restart_node(0, ['-blockfilterindex=0', f'-keypool={KEYPOOL_SIZE}'])
+
+            self.log.info(f"Running Slow rescan for interval {interval}")
+            wallet_prefix = f'rescan_{interval}_Slow'
+            min_time, max_time, avg_time = self.benchmark(node, interval, CHAIN_LENGTH, wallet_prefix)
+            results.append(("Slow", "N/A", interval, min_time, max_time, avg_time))
+            self.log.info(f"Slow Rescan Results for interval {interval}: min={min_time}ns, max={max_time}ns, avg={avg_time}ns")
+
+            for t in THREADS:
+                self.restart_node(0, ['-blockfilterindex=1', f'-walletpar={t}', f'-keypool={KEYPOOL_SIZE}'])
+                self.log.info(f"Running Fast rescan with {t} thread(s) for interval {interval}")
+                wallet_prefix = f'rescan_{interval}_{t}_Fast'
+                min_time, max_time, avg_time = self.benchmark(node, interval, CHAIN_LENGTH, wallet_prefix)
+                results.append(("Fast", t, interval, min_time, max_time, avg_time))
+                self.log.info(f"Fast Rescan Results for interval {interval} with {t} threads(s): min={min_time}ns, max={max_time}ns, avg={avg_time}ns")
+
+        # Write to output file specified in args
+        output_file = self.options.output_file
+        if output_file:
+            with open(output_file, 'w') as f:
+                f.write("Type,Threads,Interval,Min Time (us),Max Time (us),Avg Time (us)\n")
+                for scan_type, t, interval, min_time, max_time, avg_time in results:
+                    f.write(f"{scan_type},{t},{interval},{min_time // 1000},{max_time // 1000},{avg_time // 1000}\n")
+            self.log.info(f"Benchmark results written to {output_file}")
+        else:
+            self.log.info("No output file specified, skipping write.")
+
+
+if __name__ == '__main__':
+    RescanBenchmark(__file__).main()
